# ==========================================
# BSP Suryatech — Hostinger Apache SPA Router URL Rewriter
# Ensures React Router can refresh pages (History API) and never blocks API routes
# ==========================================

# STRICT SECURITY: Deny public access to database backups, schemas, credentials, and configuration files
<FilesMatch "^\.|\.(sql|db|json|md|log|env|yml|yaml|sh|key)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow high payload execution headers (Ideal for EXE and PDF manual retrievals)
  <IfModule mod_env_module>
    SetEnv LimitRequestLine 32768
  </IfModule>

  # Prevent Directory Indexing Listings
  Options -Indexes

  # Avoid rewriting files, assets, or directories that actually exist on disc
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # EXEMPTION RUNS: Prevent Apache from intercepting /api, /uploads, or /downloads
  RewriteCond %{REQUEST_URI} ^/api [NC,OR]
  RewriteCond %{REQUEST_URI} ^/uploads [NC,OR]
  RewriteCond %{REQUEST_URI} ^/downloads [NC]
  RewriteRule ^ - [L]

  # SPA ROUTER REDIRECTION: Map all virtual page URLs back to index.html
  RewriteRule . /index.html [L]
</IfModule>
